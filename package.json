    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "svelte": "^4.2.19",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "type": "module",
  "dependencies": {
    "@capacitor/android": "^8.3.0",
